# Test Environment Configuration
# Copy this file to test.env and fill in your values

# =============================================================================
# SERVER SETTINGS
# =============================================================================
TEST_SERVER_URL=http://localhost:8080
TEST_ADMIN_USER=admin
TEST_ADMIN_PASS=changeme123

# =============================================================================
# TEST USER (will be created during tests)
# =============================================================================
TEST_USER_USERNAME=testuser
TEST_USER_PASSWORD=TestPass123!
TEST_USER_EMAIL=testuser@example.com

# =============================================================================
# FILE PATHS (used for download/organize tests)
# =============================================================================
# Temporary directory for downloads
TEST_DOWNLOAD_DIR=/tmp/mediarr-tests/downloads

# Temporary directory for organized media
TEST_LIBRARY_DIR=/tmp/mediarr-tests/library

# Directory for hardlink tests (must be on same filesystem as downloads)
TEST_HARDLINK_DIR=/tmp/mediarr-tests/hardlinks

# =============================================================================
# INDEXERS (at least one is required for search tests)
# =============================================================================
# Torznab-capable indexers
# Example: Jackett, Prowlarr, NZBHydra2, or direct indexer APIs
TEST_INDEXER_1_URL=http://localhost:9117/api/v2/
TEST_INDEXER_1_API_KEY=your-jackett-api-key
TEST_INDEXER_1_NAME=Jackett

TEST_INDEXER_2_URL=
TEST_INDEXER_2_API_KEY=
TEST_INDEXER_2_NAME=

# =============================================================================
# PRIVATE TRACKERS (optional - skip if not testing private tracker features)
# =============================================================================
# RED (Redacted)
TEST_TRACKER_RED_ENABLED=false
TEST_TRACKER_RED_URL=https://redacted.ch
TEST_TRACKER_RED_USERNAME=
TEST_TRACKER_RED_PASSWORD=
TEST_TRACKER_RED_PASSKEY=

# TorrentLeech
TEST_TRACKER_TL_ENABLED=false
TEST_TRACKER_TL_URL=https://www.torrentleech.org
TEST_TRACKER_TL_USERNAME=
TEST_TRACKER_TL_PASSWORD=
TEST_TRACKER_TL_API_KEY=

# AnonMouse
TEST_TRACKER_AM_ENABLED=false
TEST_TRACKER_AM_URL=https://anonmouse.com
TEST_TRACKER_AM_USERNAME=
TEST_TRACKER_AM_PASSWORD=
TEST_TRACKER_AM_API_KEY=

# =============================================================================
# EXTERNAL APIs (for metadata search)
# =============================================================================
# TMDB (The Movie Database) - Free API key from https://www.themoviedb.org/
TEST_TMDB_API_KEY=your-tmdb-api-key

# TVDB (optional - for TV show metadata)
TEST_TVDB_API_KEY=

# =============================================================================
# TEST CONTENT
# =============================================================================
# Public domain video for download tests (Big Buck Bunny)
TEST_PUBLIC_VIDEO_NAME=Big Buck Bunny
TEST_PUBLIC_VIDEO_YEAR=2008
TEST_PUBLIC_VIDEO_TMDB_ID=251

# =============================================================================
# TEST OPTIONS
# =============================================================================
# Run slow tests (downloads, long searches)
RUN_SLOW_TESTS=false

# Cleanup test files after tests
CLEANUP_TEST_FILES=true

# Parallel test execution (may cause conflicts)
PARALLEL_TESTS=false

# Verbose output
VERBOSE_OUTPUT=true
